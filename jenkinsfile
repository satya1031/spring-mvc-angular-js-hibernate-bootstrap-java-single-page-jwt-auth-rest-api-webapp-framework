pipeline {
    agent any

    environment {
        IMAGE_NAME = "satya1031/myapp"
        IMAGE_TAG = "${BUILD_NUMBER}"
    }

    stages {

        stage('Clone Code') {
            steps {
                checkout scmGit(
                    branches: [[name: '*/master']],
                    userRemoteConfigs: [[
                        credentialsId: 'gitcred',
                        url: 'https://github.com/satya1031/spring-mvc-angular-js-hibernate-bootstrap-java-single-page-jwt-auth-rest-api-webapp-framework.git'
                    ]]
                )
            }
        }

        stage('Build WAR/JAR') {
            steps {
                sh 'mvn clean package -DskipTests'
            }
        }

        stage('Build Image (Podman)') {
            steps {
                sh 'podman build --format docker -t $IMAGE_NAME:$IMAGE_TAG .'
            }
        }

        stage('Login to Docker Hub') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'hubcred',
                    usernameVariable: 'USER',
                    passwordVariable: 'PASS'
                )]) {
                    sh 'echo $PASS | podman login -u $USER --password-stdin docker.io'
                }
            }
        }

        stage('Push Image') {
            steps {
                sh 'podman push $IMAGE_NAME:$IMAGE_TAG'
            }
        }

        stage('Deploy Container') {
            steps {
                sh '''
                podman stop myapp || true
                podman rm myapp || true
                podman run -d -p 8080:8080 --name myapp $IMAGE_NAME:$IMAGE_TAG
                '''
            }
        }
    }
}
